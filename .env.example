# Server
PORT=3001

# JWT Secret - MUST match your backend's JWT_SECRET
JWT_SECRET=your_jwt_secret_here

# Relay API Key - shared secret between Vercel backend and this relay server
RELAY_API_KEY=your_strong_random_api_key_here

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,https://your-frontend.vercel.app,https://your-superadmin.vercel.app
